# PolicyPilot Environment Configuration
# Copy this file to .env and update with your values
# This is for local development - use Railway Dashboard for production secrets

# Backend Configuration
ENVIRONMENT=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# Frontend Configuration
STREAMLIT_SERVER_HEADLESS=false
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# API Integration (for Streamlit Frontend)
# Set this to your backend URL
API_BASE_URL=http://localhost:8000

# Production Railway URLs (example - replace with your actual URLs)
# API_BASE_URL=https://policypilot-backend-production-xxxx.up.railway.app
# FRONTEND_URL=https://policypilot-frontend-production-xxxx.up.railway.app
